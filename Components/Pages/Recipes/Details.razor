@page "/recipes/{id:int}"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject RecipeStateService StateService
@inject ILogger<Details> Logger

<h3>Recipe Details</h3>

@if (recipe == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card mb-3">
        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
        {
            <img src="@recipe.ImageUrl" class="card-img-top" style="max-height: 400px; object-fit: cover;" />
        }
        <div class="card-body">
            <h2>@recipe.Title</h2>
            <p>@recipe.Description</p>
            <p><strong>⏱️ Cooking time:</strong> @recipe.CookingTimeMinutes minutes</p>
            <p><strong>📝 Ingredients:</strong></p>
            <ul>
                @foreach (var line in recipe.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                {
                    <li>@line</li>
                }
            </ul>
            <p><strong>👨‍🍳 Instructions:</strong></p>
            <ol>
                @foreach (var step in recipe.Instructions.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                {
                    <li>@step</li>
                }
            </ol>
            <p><small>Posted by @recipe.CreatedByUser?.Name on @recipe.CreatedAt.ToShortDateString()</small></p>

            <button class="btn @(isFavorited ? "btn-warning" : "btn-outline-warning")" @onclick="ToggleFavorite">
                @(isFavorited ? "❤️ Favorited" : "🤍 Favorite")
            </button>

            <div class="mt-3">
                <strong>Average rating: @averageRating⭐ (@ratingsCount ratings)</strong><br />
                <label>Your rating (1-5):</label>
                <input type="number" @bind="userRating" min="1" max="5" class="form-control w-25 d-inline ms-2" />
                <button class="btn btn-sm btn-primary ms-2" @onclick="SubmitRating">Rate</button>
            </div>

            <div class="mt-3">
                <a href="/recipes/edit/@recipe.Id" class="btn btn-secondary">Edit</a>
            </div>
        </div>
    </div>

    <h4>Comments</h4>
    <div class="mb-3">
        <textarea @bind="newCommentText" class="form-control" rows="2" placeholder="Write a comment..."></textarea>
        <button class="btn btn-primary mt-2" @onclick="AddComment">Post Comment</button>
    </div>

    @if (comments.Any())
    {
        @foreach (var comment in comments)
        {
            <div class="border p-2 mb-2">
                <strong>@comment.User?.Name</strong> <small>@comment.CreatedAt.ToShortDateString()</small>
                <p>@comment.Text</p>
            </div>
        }
    }
    else
    {
        <p>No comments yet. Be the first to comment!</p>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private Recipe? recipe;
    private List<Comment> comments = new();
    private string newCommentText = "";
    private bool isFavorited;
    private double averageRating = 0;
    private int ratingsCount = 0;
    private int userRating = 5;
    private const int CurrentUserId = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        recipe = await db.Recipes
            .Include(r => r.CreatedByUser)
            .FirstOrDefaultAsync(r => r.Id == Id);

        if (recipe == null) return;

        comments = await db.Comments
            .Include(c => c.User)
            .Where(c => c.RecipeId == Id)
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();

        isFavorited = await db.Favorites.AnyAsync(f => f.UserId == CurrentUserId && f.RecipeId == Id);

        var ratings = await db.Ratings.Where(r => r.RecipeId == Id).ToListAsync();
        ratingsCount = ratings.Count;
        averageRating = ratingsCount > 0 ? ratings.Average(r => r.Score) : 0;
    }

    private async Task ToggleFavorite()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Favorites.FirstOrDefaultAsync(f => f.UserId == CurrentUserId && f.RecipeId == Id);
            if (existing != null)
            {
                db.Favorites.Remove(existing);
                isFavorited = false;
            }
            else
            {
                db.Favorites.Add(new Favorite { UserId = CurrentUserId, RecipeId = Id });
                isFavorited = true;
            }
            await db.SaveChangesAsync();
            StateService.NotifyStateChanged();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling favorite");
        }
    }

    private async Task SubmitRating()
    {
        if (userRating < 1 || userRating > 5) return;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Ratings.FirstOrDefaultAsync(r => r.UserId == CurrentUserId && r.RecipeId == Id);
            if (existing != null)
                existing.Score = userRating;
            else
                db.Ratings.Add(new Rating { UserId = CurrentUserId, RecipeId = Id, Score = userRating });
            await db.SaveChangesAsync();

            var ratings = await db.Ratings.Where(r => r.RecipeId == Id).ToListAsync();
            ratingsCount = ratings.Count;
            averageRating = ratingsCount > 0 ? ratings.Average(r => r.Score) : 0;

            StateService.NotifyStateChanged();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting rating");
        }
    }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(newCommentText)) return;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            db.Comments.Add(new Comment
            {
                Text = newCommentText,
                RecipeId = Id,
                UserId = CurrentUserId,
                CreatedAt = DateTime.UtcNow
            });
            await db.SaveChangesAsync();

            comments = await db.Comments
                .Include(c => c.User)
                .Where(c => c.RecipeId == Id)
                .OrderByDescending(c => c.CreatedAt)
                .ToListAsync();
            newCommentText = "";

            StateService.NotifyStateChanged();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding comment");
        }
    }
}